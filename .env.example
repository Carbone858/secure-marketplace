# Database (Native PostgreSQL)
# For Vercel: use transaction pooler port 6543 with pgbouncer=true on DATABASE_URL
DATABASE_URL="postgresql://username:password@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# For migrations: use direct port 5432 on DIRECT_URL
DIRECT_URL="postgresql://username:password@aws-1-eu-north-1.pooler.supabase.com:5432/postgres"

# JWT Secret (generate a secure random string, min 32 characters)
JWT_SECRET="your-super-secure-jwt-secret-min-32-characters-long"

# reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"

# SMTP Configuration (for email sending)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
FROM_EMAIL="noreply@servicemarketplace.com"
FROM_NAME="Service Marketplace"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Analytics & Tracking (Google Analytics / Google Tag Manager)
NEXT_PUBLIC_GA_TRACKING_ID="your-ga4-tracking-id"
NEXT_PUBLIC_GTM_CONTAINER_ID="your-gtm-container-id"

# Node Environment
NODE_ENV="development"

# Redis (optional - enables distributed rate limiting; falls back to in-memory)
REDIS_URL="redis://localhost:6379"

# Rate Limiting (optional - defaults shown)
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_REGISTER_WINDOW_SEC=300
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_SEC=900
RATE_LIMIT_API_MAX=60
RATE_LIMIT_API_WINDOW_SEC=60

# Telegram Auth
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
NEXT_PUBLIC_TELEGRAM_BOT_NAME="your-telegram-bot-name"
NEXT_PUBLIC_TELEGRAM_BOT_ID="your-telegram-bot-id"
